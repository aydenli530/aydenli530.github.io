5) 參考代碼片段（可直接嵌入）
-----------------------------
A) 最小回聲版（排障用）
--------------------------------
export default {
  async fetch(request) {
    try {
      const origin = request.headers.get("Origin") || "";
      const raw = await request.text();
      return new Response(JSON.stringify({ ok: true, method: request.method, path: new URL(request.url).pathname, origin, length: raw.length, snippet: raw.slice(0, 100) }), {
        status: 200,
        headers: {
          "Content-Type": "application/json; charset=utf-8",
          "Access-Control-Allow-Origin": origin || "",
          "Vary": "Origin"
        }
      });
    } catch (e) {
      return new Response(String(e?.stack || e), {
        status: 500,
        headers: {
          "Access-Control-Allow-Origin": request.headers.get("Origin") || "",
          "Vary": "Origin",
          "Content-Type": "text/plain; charset=utf-8"
        }
      });
    }
  }
}

B) 重新包裝上游回應（避免 500）
-------------------------------------
// 假設已完成：OPTIONS 放行、Origin 正規化、白名單檢查、參數驗證、cacheKey 準備
try {
  const upstream = await fetch(fhl.toString(), {
    method: "GET",
    headers: {
      "User-Agent": "Mozilla/5.0",
      "Accept": "application/json,text/plain;q=0.9,*/*;q=0.8"
    }
  });

  const text = await upstream.text();
  let isJson = false;
  try { JSON.parse(text); isJson = true; } catch {}

  const resp = new Response(text, {
    status: upstream.status,
    headers: {
      "Content-Type": isJson ? "application/json; charset=utf-8" : "text/plain; charset=utf-8",
      "Cache-Control": `public, max-age=60, stale-while-revalidate=120`
    }
  });

  if (upstream.ok && isJson) {
    const toCache = new Response(text, { status: 200, headers: { "Content-Type": "application/json; charset=utf-8" } });
    ctx.waitUntil(caches.default.put(cacheKey, toCache));
  }

  return addCors(resp, isAllowedOrigin, rawOrigin);
} catch (e) {
  return addCors(new Response("Upstream Fetch Error", { status: 502 }), isAllowedOrigin, rawOrigin);
}

C) 嚴格模式骨架（含 OPTIONS 放行）
--------------------------------------
// OPTIONS（預檢）
if (request.method === "OPTIONS") {
  const reqHeaders = request.headers.get("Access-Control-Request-Headers") || "";
  const headers = buildCorsHeaders(isAllowedOrigin, rawOrigin, {
    "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
    "Access-Control-Allow-Headers": reqHeaders || "Content-Type",
    "Access-Control-Max-Age": "86400"
  });
  return new Response(null, { headers });
}

// 嚴格限制入口（只允許白名單且必須帶 Origin）
if (!rawOrigin || !isAllowedOrigin) {
  return new Response("Forbidden", { status: 403 });
}

// 其後才是業務邏輯…

